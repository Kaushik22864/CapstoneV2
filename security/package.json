{
  "name": "oct-security-framework",
  "version": "1.0.0",
  "description": "Self-contained security layer for the OCT diagnostic capstone project (Group 46)",
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:auth": "jest tests/auth.test.js --verbose",
    "test:rbac": "jest tests/rbac.test.js --verbose",
    "test:file": "jest tests/fileValidator.test.js --verbose",
    "test:validators": "jest tests/validators.test.js --verbose",
    "test:password": "jest tests/passwordUtils.test.js --verbose",
    "test:audit": "jest tests/auditLogger.test.js --verbose"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "file-type": "^16.5.4",
    "jsonwebtoken": "^9.0.2",
    "mongo-sanitize": "^1.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "winston": "^3.13.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}