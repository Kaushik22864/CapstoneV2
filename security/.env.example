# Database Configuration
MONGODB_URI=mongodb://localhost:27017/oct_system

# JWT Configuration
JWT_SECRET=your_super_secret_access_token_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=oct-diagnostic-system

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# Encryption (AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_IV=0123456789abcdef0123456789abcdef

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=10
RATE_LIMIT_MAX_REGISTER=5
RATE_LIMIT_WHITELIST=127.0.0.1

# File Uploads
MAX_UPLOAD_BYTES=5242880
UPLOAD_DIR=./uploads/temp

# Audit Logging
AUDIT_LOG_PATH=./logs/audit.log